								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.success && jsonData.data) {",
									"        pm.collectionVariables.set('bookingId', jsonData.data.id);",
									"        console.log('✅ Booking created with ID:', jsonData.data.id);",

									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Tạo thời gian booking trong tương lai",
									"var now = new Date();",
									"var tomorrow = new Date(now.getTime() + 24 * 60 * 60 * 1000);",
									"",
									"// Set thời gian 10:00 sáng",
									"var startTime = new Date(tomorrow);",
									"startTime.setHours(10, 0, 0, 0);",
									"",
									"// Set thời gian 12:00 trưa",
									"var endTime = new Date(tomorrow);",
									"endTime.setHours(12, 0, 0, 0);",
									"",
									"pm.collectionVariables.set('bookingStartTime', startTime.toISOString());",
									"pm.collectionVariables.set('bookingEndTime', endTime.toISOString());"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
